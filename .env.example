# ── evento-navecon — variáveis de ambiente ────────────────────────────────
# Copie para .env e preencha. O .env NUNCA vai pro git (está no .gitignore).
# "Configuração vem do ambiente, não do código."

# App
NODE_ENV=production
# Porta publicada no host, só em loopback (interna é sempre 3000). Par: 4099/5099.
APP_PORT=4099
# Domínio de produção (usado pelo Caddy no docker-compose.prod.yml para o TLS).
# Precisa ter DNS (A/AAAA) apontando pro IP do servidor. Ex.: imersao.navecon.com.br
DOMAIN=
# URL pública do site — usada nos back_urls e no webhook do Mercado Pago.
# Em produção: https://SEU_DOMINIO  |  Em dev local: http://localhost:4099
PUBLIC_BASE_URL=http://localhost:4099

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=evento
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=evento_navecon
# Porta do banco publicada no host (interna é sempre 5432).
DB_PORT=5099

# ── Mercado Pago ───────────────────────────────────────────────────────────
# SECRETO — só no servidor, nunca no frontend nem no git.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxx
# Pública por design (só necessária se um dia migrar pro Checkout Bricks;
# no Checkout Pro por redirect não é usada).
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Valor do ingresso em centavos (R$ 1.899,00 = 189900) e nº máximo de parcelas.
TICKET_PRICE_CENTS=189900
MAX_INSTALLMENTS=6
TICKET_TITLE=Imersão Marketplaces e Inteligência Tributária — Navecon

# ── E-mail (Gmail SMTP com senha de app) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=noreply.navecon@gmail.com
# Senha de app do Gmail (16 caracteres). SECRETO.
SMTP_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM=Navecon Contabilidade <noreply.navecon@gmail.com>
# Quem recebe o aviso de cada nova inscrição (a equipe responsável pelo cadastro).
NOTIFY_EMAIL=mkt@navecon.net.br

# ── Reconciliação de pagamento ─────────────────────────────────────────────
# Intervalo do poller que confere pagamentos pendentes no MP (ms). Essencial
# pro pix, que é pago depois. Webhook cobre o caso instantâneo quando há IP público.
POLL_INTERVAL_MS=120000
